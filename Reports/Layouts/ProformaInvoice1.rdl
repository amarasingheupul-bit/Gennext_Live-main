  </ReportSections>
  <Code>Public Function BlankZero(ByVal Value As Decimal)
    if Value = 0 then
        Return ""
    end if
    Return Value
End Function

Public Function BlankPos(ByVal Value As Decimal)
    if Value &gt; 0 then
        Return ""
    end if
    Return Value
End Function

Public Function BlankZeroAndPos(ByVal Value As Decimal)
    if Value &gt;= 0 then
        Return ""
    end if
    Return Value
End Function

Public Function BlankNeg(ByVal Value As Decimal)
    if Value &lt; 0 then
        Return ""
    end if
    Return Value
End Function

Public Function BlankNegAndZero(ByVal Value As Decimal)
    if Value &lt;= 0 then
        Return ""
    end if
    Return Value
End Function

Public shared LineNo As Decimal
Public Function Sn(Value As String)
    if Value &lt;&gt; "" then
       LineNo = LineNo +1
      Return LineNo 
     end if
    Return ""
End Function

Public Function ZeroVal(Value As Decimal)
    if Value &lt;&gt; 0 then
            Return Value  
     end if
End Function

